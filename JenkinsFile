pipeline {
    agent {
        label 'slaveEC2'
    }
    environment {
        USERNAME = 'akyadav113114 (from jenkin file environment)'
    }
    parameters {
        string(name: 'USERNAME', defaultValue: 'akyadav113114 (from jenkin file parameters)', description: 'Username for the Jenkins pipeline')
        choice(name: "DeployState", choices: ['Dream','Prod'], description: 'deployment choice')
    }
    stages {
        stage('build') {
            steps {
                echo "Building the application...${env.USERNAME}"
                echo "this is parameter data: ${params.USERNAME}"
            }
        }
        stage('testDeployParallelExec'){
            parallel{
                stage('test') {
                    // agent {
                    //     label 'Built-In Node'
                    // }
                    steps {
                        echo "Running the test"
                        sh 'python3 pythoncode/test.py'
                    }
                    post {
                        always {
                            stash includes: 'pythoncode/*.py', name: 'py_artifact_stash', allowEmpty: true
                        }
                    }
                }
                stage('deployInDreams') {
                    agent {
                        label 'slaveEC2'
                    }
                    steps {
                        echo "Deploying the application...in dreams."
                    }
                }
            }
            post {
                success {
                    echo "all tests and deployment passed !"
                    file = load('pythoncode/myScript.groovy')
                    file.hello()
                }
                failure {
                    echo "some tests or deployment failed !"
                    file = load('pythoncode/myScript.groovy')
                    file.hello()
                }
            }
        }
        stage('deployInRealLife') {
            when {
                beforeAgent true
                expression {
                    params.DeployState == 'Prod'
                }
            }

            agent {
                label 'slaveEC2'
            }

            steps {
                unstash 'py_artifact_stash'
                echo "Deploying the application...in real life."
            }
        }
    }
}