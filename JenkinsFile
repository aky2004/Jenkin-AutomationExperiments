pipeline {
    agent {
        label 'slaveEC2'
    }
    stages {
        stage('build') {
            steps {
                echo "Building the application..."
            }
        }
        stage('test') {
            steps {
                echo "Running the test..."
                sh 'python3 pythoncode/test.py'
            }
            post {
                always {
                    archiveArtifacts artifacts: 'pythoncode/*.py', allowEmptyArchive: true
                }
                success {
                    echo "all tests passed!"
                }
                failure {
                    echo "some tests failed!"
                }
            }
        }
        stage('deploy') {
            steps {
                echo "Deploying the application..."
            }
        }
    }
}