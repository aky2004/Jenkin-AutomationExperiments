pipeline {
    agent {
        label 'slaveEC2'
    }
    environment {
        USERNAME = 'akyadav113114 (from jenkin file environment)'
    }
    parameters {
        string(name: 'USERNAME', defaultValue: 'akyadav113114 (from jenkin file parameter)', description: 'Username for the Jenkins pipeline')
    }
    stages {
        stage('build') {
            steps {
                echo "Building the application...${env.USERNAME}"
                echo "this is parameter data: ${params.USERNAME}"
            }
        }
        stage('test') {
            steps {
                echo "Running the test...${env.USERNAME}"
                sh 'python3 pythoncode/test.py'
            }
            post {
                always {
                    archiveArtifacts artifacts: 'pythoncode/*.py', allowEmptyArchive: true
                }
                success {
                    echo "all tests passed...${env.USERNAME}"
                }
                failure {
                    echo "some tests failed...${env.USERNAME}"
                }
            }
        }
        stage('deploy') {
            steps {
                echo "Deploying the application...${env.USERNAME}"
            }
        }
    }
}